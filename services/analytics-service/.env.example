# Application
APP_ENV=development
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=energy_platform
MYSQL_USER=energy
MYSQL_PASSWORD=energy
MYSQL_POOL_SIZE=10

# AWS S3
S3_BUCKET_NAME=energy-platform-datasets
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ML Configuration
DEFAULT_TRAIN_TEST_SPLIT=0.8
MAX_DATASET_SIZE_MB=500

# Job Worker
MAX_CONCURRENT_JOBS=3
JOB_TIMEOUT_SECONDS=3600
